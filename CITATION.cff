title: "Representation Economy and the SENSE–CORE–DRIVER Framework"

type: generic

authors:
  - family-names: Singh
    given-names: Raktim
    affiliation: "Independent Researcher"
    orcid: "https://orcid.org/0009-0002-6207-602X"
